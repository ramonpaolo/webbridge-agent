# Agent WebSocket URL (where your nanobot is running)
# Default for docker-compose setup: ws://nanobot:18791
AGENT_WS_URL=ws://nanobot:18791

# Your API key (must match allowed_connections in agent config)
API_KEY=your_api_key_here

# Optional HMAC secret for message signatures
HMAC_SECRET=

# Display name for the agent
AGENT_NAME=Agent

# Server port
PORT=8080

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=*
